# Production .env template for ramkiransblog on Lightsail + Caddy.
# Copy to `.env` on the VM and fill in the REPLACE_ME values with secrets
# generated locally (never commit real secrets):
#
#   python3 -c 'import secrets; print(secrets.token_urlsafe(50))'   # SECRET_KEY
#   python3 -c 'import secrets; print(secrets.token_urlsafe(32))'   # POSTGRES_PASSWORD
#   python3 -c 'import secrets; print(secrets.token_urlsafe(8) + "/")'  # DJANGO_ADMIN_URL

# Public domain Caddy serves on. Must also appear in ALLOWED_HOSTS and
# CSRF_TRUSTED_ORIGINS below.
DOMAIN=ramkiransblog.com

# Django
DEBUG=False
SECRET_KEY=REPLACE_ME_RUN_secrets.token_urlsafe(50)
ALLOWED_HOSTS=ramkiransblog.com
CSRF_TRUSTED_ORIGINS=https://ramkiransblog.com
# Obscure admin path. Do NOT reuse `rk-admin/` — that value is in git history.
DJANGO_ADMIN_URL=REPLACE_ME_FRESH_SLUG/

# Database — password here MUST match POSTGRES_PASSWORD below, otherwise
# the compose default `blog` masks it and psycopg auth fails.
DATABASE_URL=postgres://blog:REPLACE_ME_POSTGRES_PASSWORD@db:5432/blog

# Postgres container config
POSTGRES_USER=blog
POSTGRES_PASSWORD=REPLACE_ME_POSTGRES_PASSWORD
POSTGRES_DB=blog
